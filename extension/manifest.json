{
  "manifest_version": 3,
  "name": "OneResume Connect",
  "version": "1.1.1",
  "description": "OneResume 마스터 이력서를 채용 사이트에 자동으로 동기화합니다.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://api.oneresume.kr/*",
    "*://localhost/*",
    "*://*.saramin.co.kr/*",
    "*://*.wanted.co.kr/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "*://localhost/*",
        "*://*.oneresume.kr/*",
        "*://*.saramin.co.kr/*",
        "*://*.wanted.co.kr/*"
      ],
      "js": ["content.js"]
    }
  ]
}
